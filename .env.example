# ============================================================
# Easy2Book Travel Planner - Variables d'environnement Production
# ============================================================
# Copier ce fichier en .env.local et remplir les valeurs reelles.
# NE JAMAIS commiter .env.local.
# ============================================================

# --- Base de donnees (serveur uniquement) ---
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/easy2book_travelplanner?sslmode=require

# --- Intelligence Artificielle (serveur uniquement) ---
OPENAI_API_KEY=sk-...

# --- Application & Reseau (public, necessaire pour CORS et deduplication) ---
NEXT_PUBLIC_APP_URL=https://easy2book.tn
NEXT_PUBLIC_WEBSITE_URL=https://easy2book.tn

# --- WhatsApp (liens wa.me actuellement utilises) ---
NEXT_PUBLIC_WHATSAPP_NUMBER=+216XXXXXXXX

# --- WhatsApp Business API (optionnel, pour envoi automatique des bons de commande) ---
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here

# --- Meta Conversions API (Pixel navigateur + CAPI serveur) ---
NEXT_PUBLIC_META_PIXEL_ID=your_pixel_id_here
META_ACCESS_TOKEN=your_meta_access_token_here
META_APP_SECRET=your_meta_app_secret_here

# --- Facebook Leads Webhook (serveur uniquement) ---
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
META_WEBHOOK_VERIFY_TOKEN=easy2book-verify-token

# --- Branding (public) ---
NEXT_PUBLIC_BRAND_EMAIL=contact@easy2book.tn
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/easy2book
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/easy2book
